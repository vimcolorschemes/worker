#!/usr/bin/env bash

set -euo pipefail

BREAK_LINE="
"

require_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "Missing required command: $1"
    exit 1
  fi
}

require_var() {
  local name="$1"
  if [ -z "${!name:-}" ]; then
    echo "Missing required env var in .env.deploy: ${name}"
    exit 1
  fi
}

require_cmd docker
require_cmd aws

if ! docker --version >/dev/null 2>&1; then
  echo "Please install Docker Desktop"
  echo "https://www.docker.com/products/docker-desktop/"
  exit 1
fi

if ! docker info >/dev/null 2>&1; then
  echo "Please run Docker Desktop"
  echo "https://docs.docker.com/desktop/"
  exit 1
fi

if [ ! -f .env.deploy ]; then
  echo "Missing .env.deploy"
  echo "Create .env.deploy and set values"
  exit 1
fi

echo "
 _  __(_)_ _  _______  / /__  _______ ____/ /  ___ __ _  ___ ___
| |/ / /  ' \/ __/ _ \/ / _ \/ __(_-</ __/ _ \/ -_)  ' \/ -_|_-<
|___/_/_/_/_/\__/\___/_/\___/_/ /___/\__/_//_/\__/_/_/_/\__/___/
                   _    _____  ____/ /_____ ____
                  | |/|/ / _ \/ __/  '_/ -_) __/
                  |__,__/\___/_/ /_/\_\\__/_/
"

echo "${BREAK_LINE}Sourcing .env.deploy"
source .env.deploy

require_var AWS_PROFILE
require_var AWS_REGISTRY_ID
require_var AWS_REGION

AWS_REPOSITORY="vimcolorschemes/worker"
IMAGE_URI_BASE="${AWS_REGISTRY_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${AWS_REPOSITORY}"
IMAGE_URI_LATEST="${IMAGE_URI_BASE}:latest"

echo "${BREAK_LINE}Checking ECR repository"
aws ecr describe-repositories --region "$AWS_REGION" --profile "$AWS_PROFILE" --repository-names "$AWS_REPOSITORY" >/dev/null

echo "${BREAK_LINE}Logging in to ECR"
aws ecr get-login-password --region "$AWS_REGION" --profile "$AWS_PROFILE" | docker login --username AWS --password-stdin "${AWS_REGISTRY_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"

echo "${BREAK_LINE}Building the docker image"
docker build --platform linux/amd64 -t "$IMAGE_URI_LATEST" .

echo "${BREAK_LINE}Pushing latest tag"
docker push "$IMAGE_URI_LATEST"

echo "${BREAK_LINE}Done"
echo "Image: ${IMAGE_URI_LATEST}"
